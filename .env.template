# GitHub personal access token.
# Required permissions:
#   Classic token:            repo (full control of private/public repositories)
#   Fine-grained token:       Contents (read/write), Issues (read/write),
#                             Pull requests (read/write), Metadata (read)
GITHUB_TOKEN=

# Target repository owner (e.g. niconorsk)
GITHUB_OWNER=

# Target repository name (e.g. responsible-ai-agent)
GITHUB_REPO=

# Pydantic AI Gateway API key used by the agent
PYDANTIC_AI_GATEWAY_API_KEY=
